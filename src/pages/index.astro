---
import Layout from "../layouts/Layout.astro";
---

<Layout title="The Cloud Pundits">

<!-- HERO -->
<div class="hero">
  <h1>Cloud & AI Intelligence Platform</h1>
  <p>
    Track real-time developments in AWS, Azure, AI models, DevOps systems,
    FinOps strategies, and security intelligence — curated by Crossbill Ltd.
  </p>
</div>

<!-- WHAT WE TRACK -->
<div class="section-title">🚀 What we track</div>

<div class="grid">

  <a class="card cloud" href="/cloud">
    ☁️ <b>Cloud Engineering</b>
    <p>AWS, Azure, GCP, architecture & scalability trends</p>
  </a>

  <a class="card ai" href="/ai">
    🤖 <b>AI Systems</b>
    <p>LLMs, agents, model releases, AI tooling</p>
  </a>

  <a class="card devops" href="/devops">
    ⚙️ <b>DevOps</b>
    <p>CI/CD, Kubernetes, infrastructure automation</p>
  </a>

  <a class="card finops" href="/finops">
    💰 <b>FinOps</b>
    <p>Cloud cost optimization & financial operations</p>
  </a>

  <!-- 🔐 NEW ADDITION -->
  <a class="card secops" href="/secops">
    🔐 <b>SecOps</b>
    <p>Security, vulnerabilities, threat intelligence, IAM</p>
  </a>

</div>

<!-- LIVE INTELLIGENCE -->
<div class="section-title">📊 Live Intelligence Preview</div>

<div class="grid">

  <div class="card cloud">
    <b>Latest Cloud Insight</b>
    <p>AWS, Kubernetes and serverless adoption trends...</p>
  </div>

  <div class="card ai">
    <b>AI Breakthroughs</b>
    <p>New model architectures and agent workflows...</p>
  </div>

  <div class="card finops">
    <b>FinOps Signal</b>
    <p>Cost optimization strategies used by enterprises...</p>
  </div>

  <!-- 🔐 NEW SECOPS SIGNAL -->
  <div class="card secops">
    <b>Security Intelligence</b>
    <p>Latest vulnerabilities, attack patterns and defense strategies...</p>
  </div>

</div>

</Layout>
